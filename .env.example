# ============================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ============================================
# Copie este arquivo para .env e preencha com seus valores reais
# ATENÇÃO: Nunca commite o arquivo .env no Git!

# ============================================
# DOCKER HUB
# ============================================
# Username do Docker Hub (obrigatório para deploy)
DOCKERHUB_USERNAME=seu_username_dockerhub

# Versão da imagem a ser usada (latest, v1.0.0, etc)
IMAGE_TAG=latest

# ============================================
# SSL / DOMÍNIO
# ============================================
# Domínio da aplicação (obrigatório para Let's Encrypt)
# Para teste local, use: gestaointegrada.local
DOMAIN=gestaointegrada.local

# Email para notificações do Let's Encrypt (obrigatório)
EMAIL=seu-email@exemplo.com

# Usar certificado autoassinado? (true para testes locais, false para produção)
USE_SELF_SIGNED=true

# ============================================
# BANCO DE DADOS
# ============================================
# URL de conexão completa do PostgreSQL
# Formato: jdbc:postgresql://host:porta/nome_banco
DATABASE_URL=jdbc:postgresql://seu-servidor-db:5432/gestao_integrada_db

# Usuário do banco de dados
DATABASE_USERNAME=seu_usuario

# Senha do banco de dados
DATABASE_PASSWORD=sua_senha_segura

# ============================================
# JWT KEYS
# ============================================
# Caminho para o diretório com as chaves RSA (fora do projeto)
# Gere com:
#   mkdir -p ~/.gestao-integrada/keys
#   openssl genrsa -out ~/.gestao-integrada/keys/app.key 2048
#   openssl rsa -in ~/.gestao-integrada/keys/app.key -pubout -out ~/.gestao-integrada/keys/app.pub
JWT_KEYS_PATH=/home/seu-usuario/.gestao-integrada/keys

# ============================================
# SEGURANÇA
# ============================================
# Token administrativo para gestão de tenants
# Gere com: openssl rand -hex 32
APP_ADMIN_TOKEN=seu_token_admin_seguro

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. DNS: Antes de subir a aplicação, configure o DNS do seu domínio
#    para apontar para o IP do servidor onde o Docker está rodando.
#
# 2. Firewall: Libere as portas 80 (HTTP) e 443 (HTTPS) no firewall.
#
# 3. Certificado SSL: Na primeira execução, o Let's Encrypt irá validar
#    o domínio. Certifique-se de que o DNS está configurado corretamente.
#
# 4. Segurança: Use senhas fortes para o banco de dados e gere um
#    APP_ADMIN_TOKEN único com: openssl rand -hex 32
