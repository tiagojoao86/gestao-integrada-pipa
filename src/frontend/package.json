    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.15",
    "@angular/platform-browser-dynamic": "^20.3.15",
    "@angular/router": "^20.3.15",
    "@primeng/themes": "^20.4.0",
    "class-transformer": "^0.5.1",
    "jwt-decode": "^4.0.0",
